{
  "schemaVersion": 2,
  "locals": [],
  "nodes": [
    {
      "id": "n_start",
      "nodeType": "flow.start",
      "params": {
        "dynamicOutputs": [
          { "name": "basePrice", "label": "基础价格", "valueType": "Decimal", "required": true },
          { "name": "taxRate", "label": "税率(0..1)", "valueType": "Ratio", "required": true },
          { "name": "discountRate", "label": "折扣(0..1)", "valueType": "Ratio", "required": true }
        ]
      }
    },
    {
      "id": "n_end",
      "nodeType": "flow.end",
      "params": {
        "dynamicInputs": [
          {
            "name": "finalPrice",
            "label": "最终价格",
            "valueType": "Decimal",
            "rounding": { "scale": 2, "mode": "HALF_UP" }
          }
        ]
      }
    },
    { "id": "n_tax", "nodeType": "math.mul" },
    { "id": "n_priceWithTax", "nodeType": "math.add" },
    { "id": "n_one", "nodeType": "core.const.decimal", "params": { "value": "1" } },
    { "id": "n_discountFactor", "nodeType": "math.sub" },
    { "id": "n_final", "nodeType": "math.mul" }
  ],
  "edges": [
    { "from": { "nodeId": "n_start", "port": "basePrice" }, "to": { "nodeId": "n_tax", "port": "a" } },
    { "from": { "nodeId": "n_start", "port": "taxRate" }, "to": { "nodeId": "n_tax", "port": "b" } },

    { "from": { "nodeId": "n_start", "port": "basePrice" }, "to": { "nodeId": "n_priceWithTax", "port": "a" } },
    { "from": { "nodeId": "n_tax", "port": "value" }, "to": { "nodeId": "n_priceWithTax", "port": "b" } },

    { "from": { "nodeId": "n_one", "port": "value" }, "to": { "nodeId": "n_discountFactor", "port": "a" } },
    { "from": { "nodeId": "n_start", "port": "discountRate" }, "to": { "nodeId": "n_discountFactor", "port": "b" } },

    { "from": { "nodeId": "n_priceWithTax", "port": "value" }, "to": { "nodeId": "n_final", "port": "a" } },
    { "from": { "nodeId": "n_discountFactor", "port": "value" }, "to": { "nodeId": "n_final", "port": "b" } },

    { "from": { "nodeId": "n_final", "port": "value" }, "to": { "nodeId": "n_end", "port": "finalPrice" } }
  ],
  "execEdges": [{ "from": { "nodeId": "n_start", "port": "out" }, "to": { "nodeId": "n_end", "port": "in" } }],
  "metadata": {
    "ui": {
      "nodes": {
        "n_start": { "x": 0, "y": 0 },
        "n_tax": { "x": 80, "y": -140 },
        "n_priceWithTax": { "x": 360, "y": -140 },
