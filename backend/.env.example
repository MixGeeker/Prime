# ============================================================
# Compute Engine Backend - .env 示例（可复制为 `.env`）
# ============================================================
# 说明：
# - 本文件用于本地开发/联调的默认配置示例。
# - 所有变量都会经过 `backend/src/config/env.validation.ts` 校验与默认值填充。
# - 每个配置都给出：作用 / 示例 / 含义（便于部署侧写 Helm/K8s/Compose）。
# ============================================================

# ----------------------
# HTTP（主进程 /admin）
# ----------------------

# HTTP_PORT
# 作用：HTTP 服务监听端口（Admin API + health/ready + 可选 metrics）。
# 示例：4010
# 含义：进程内部监听端口；对外端口由反向代理/Ingress/端口映射决定。
HTTP_PORT=4010

# SWAGGER_PATH
# 作用：Swagger UI 路径。
# 示例：/docs
# 含义：访问地址为 `http://<host>:<HTTP_PORT><SWAGGER_PATH>`。
SWAGGER_PATH=/docs

# READY_CHECK_CACHE_MS
# 作用：`GET /ready` 依赖探测结果缓存时长（ms）。
# 示例：1000
# 含义：避免 readiness 高频探测压垮 DB/MQ；建议 500~2000ms。
READY_CHECK_CACHE_MS=1000

# READY_CHECK_DB_TIMEOUT_MS
# 作用：`GET /ready` 探测 DB 的超时（ms）。
# 示例：500
# 含义：超时会判定为 not ready；建议 200~800ms（视内网延迟与 DB 压力调整）。
READY_CHECK_DB_TIMEOUT_MS=500

# READY_CHECK_MQ_TIMEOUT_MS
# 作用：`GET /ready` 探测 RabbitMQ 的超时（ms）。
# 示例：800
# 含义：超时会判定为 not ready；建议 300~1500ms（视网络与 MQ 压力调整）。
READY_CHECK_MQ_TIMEOUT_MS=800

# ----------------------
# Database（PostgreSQL）
# ----------------------

# DATABASE_URL
# 作用：PostgreSQL 连接串（TypeORM 使用；跑迁移/落 jobs/outbox/releases 必需）。
# 示例：postgresql://postgres:postgres@localhost:5432/compute_engine
# 含义：postgresql://{user}:{password}@{host}:{port}/{database}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/compute_engine

# ----------------------
# RabbitMQ（Worker consumer/dispatcher）
# ----------------------

# RABBITMQ_URL
# 作用：RabbitMQ 连接串（amqplib 使用；当 WORKER_ROLES 启用 consumer/dispatcher 时必填）。
# 示例：amqp://guest:guest@localhost:5672
# 含义：amqp://{user}:{password}@{host}:{port}
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ----------------------
# Worker（角色/拓扑/消费/Outbox）
# ----------------------

# WORKER_ROLES
# 作用：控制当前 worker 进程要启用哪些能力。
# 示例：consumer,dispatcher（同进程消费 + 出站发布）
# 含义：
# - consumer：消费 `compute.job.requested.v1`
# - dispatcher：Outbox dispatcher（发布 succeeded/failed 事件）
# - maintenance：运维/清理任务（例如 retention cleaner）
WORKER_ROLES=consumer,dispatcher

# MQ_COMMANDS_EXCHANGE
# 作用：命令 exchange（Compute Engine 从这里绑定队列消费 job.requested）。
# 示例：compute.commands
# 含义：topic + durable；routingKey 约定见 `API_DESIGN.md`。
MQ_COMMANDS_EXCHANGE=compute.commands

# MQ_EVENTS_EXCHANGE
# 作用：事件 exchange（Compute Engine 从 Outbox 发布 succeeded/failed）。
# 示例：compute.events
# 含义：topic + durable；由部署侧决定是否落审计/转发到别的系统。
MQ_EVENTS_EXCHANGE=compute.events

# MQ_DLX_EXCHANGE
# 作用：死信 exchange（消费失败/拒绝后进入 DLQ）。
# 示例：compute.dlx
# 含义：topic + durable；用于收敛不可恢复消息与回放（replay）。
MQ_DLX_EXCHANGE=compute.dlx

# MQ_JOB_REQUESTED_QUEUE
# 作用：`compute.job.requested.v1` 的 consumer queue 名称。
# 示例：compute.job.requested.v1
# 含义：durable；会绑定到 MQ_COMMANDS_EXCHANGE 上的 routingKey `compute.job.requested.v1`。
MQ_JOB_REQUESTED_QUEUE=compute.job.requested.v1

# MQ_PREFETCH
# 作用：consumer prefetch（每个 channel 最大未 ack 消息数）。
# 示例：10
# 含义：越大吞吐越高但峰值内存更高；建议结合节点复杂度与 DB 写入能力调参。
MQ_PREFETCH=10

# MQ_MAX_MESSAGE_BYTES
# 作用：单条消息体最大字节数（过大直接拒绝进入 DLQ，避免 worker OOM）。
# 示例：1000000（约 1MB）
# 含义：上游如需更大 payload，建议把大 JSON 存对象存储，仅传引用。
MQ_MAX_MESSAGE_BYTES=1000000

# OUTBOX_DISPATCH_BATCH_SIZE
# 作用：Outbox dispatcher 每次拉取/加锁的最大记录数。
# 示例：50
# 含义：过大可能导致单批耗时过长；建议与 OUTBOX_DISPATCH_POLL_INTERVAL_MS 协调。
OUTBOX_DISPATCH_BATCH_SIZE=50

# OUTBOX_DISPATCH_POLL_INTERVAL_MS
# 作用：Outbox dispatcher 轮询间隔（ms）。
# 示例：500
# 含义：越小延迟越低但 DB 压力更高；生产建议 200~2000ms 视吞吐而定。
OUTBOX_DISPATCH_POLL_INTERVAL_MS=500

# OUTBOX_DISPATCH_LEASE_MS
# 作用：Outbox dispatcher 租约时长（ms），超过视为锁过期可被其他实例抢占。
# 示例：30000（30s）
# 含义：需要大于“单批发布最大耗时”；过小会导致重复发布压力，过大影响故障切换。
OUTBOX_DISPATCH_LEASE_MS=30000

# OUTBOX_DISPATCH_MAX_ATTEMPTS
# 作用：Outbox dispatcher 对单条 outbox 的最大自动重试次数。
# 示例：25
# 含义：超过后不再自动重试（需人工介入/告警/回放策略）。
OUTBOX_DISPATCH_MAX_ATTEMPTS=25

# ----------------------
# Metrics（Prometheus）
# ----------------------

# METRICS_ENABLED
# 作用：是否启用 Prometheus metrics。
# 示例：true
# 含义：启用后会在 HTTP 进程（HTTP_PORT）和 Worker 进程（WORKER_METRICS_PORT）暴露 metrics。
METRICS_ENABLED=true

# METRICS_PATH
# 作用：metrics 路径。
# 示例：/metrics
# 含义：访问地址为 `http://<host>:<port><METRICS_PATH>`。
METRICS_PATH=/metrics

# METRICS_COLLECT_DEFAULT
# 作用：是否启用 prom-client 默认进程指标（CPU/内存/事件循环等）。
# 示例：true
# 含义：关闭可减少 metrics 体积与采集开销。
METRICS_COLLECT_DEFAULT=true

# WORKER_METRICS_PORT
# 作用：Worker 进程暴露 metrics 的 HTTP 端口（Worker 采用 ApplicationContext，不占用 HTTP_PORT）。
# 示例：4020
# 含义：仅当你启动 `npm run start:worker`（或生产 worker）时生效。
WORKER_METRICS_PORT=4020

# ----------------------
# Admin（危险运维端点）
# ----------------------

# ADMIN_DANGEROUS_ENDPOINTS_ENABLED
# 作用：是否允许启用危险运维端点（例如 DLQ replay）。
# 示例：false
# 含义：生产默认建议 false；需要操作时短期开启并配合强鉴权与审计。
ADMIN_DANGEROUS_ENDPOINTS_ENABLED=false

# ADMIN_API_TOKEN
# 作用：危险端点鉴权 token。
# 示例：<填一个长随机串>
# 含义：请求需携带 `Authorization: Bearer <token>`；空字符串等同未配置。
ADMIN_API_TOKEN=

# DLQ_REPLAY_MAX_LIMIT
# 作用：DLQ replay 单次最大回放条数（硬上限）。
# 示例：200
# 含义：防止误操作导致一次性回放过多消息压垮 DB/worker。
DLQ_REPLAY_MAX_LIMIT=200

# ----------------------
# Logging
# ----------------------

# LOG_LEVEL
# 作用：应用日志级别（映射到 Nest logger levels）。
# 示例：info
# 含义：可选值：error | warn | info | debug | verbose
LOG_LEVEL=info

# ----------------------
# Retention（保留策略，单位：天）
# ----------------------

# OUTBOX_SENT_TTL_DAYS
# 作用：已发送 outbox 记录保留天数。
# 示例：30
# 含义：只清理 outbox 已发送记录，不影响幂等与追溯。
OUTBOX_SENT_TTL_DAYS=30

# JOBS_SNAPSHOT_TTL_DAYS
# 作用：jobs 快照（inputs/outputs 大 JSON）保留天数。
# 示例：180
# 含义：超过后会把快照字段置空（保留 job 元数据），避免表无限膨胀。
JOBS_SNAPSHOT_TTL_DAYS=180

# DRAFT_TTL_DAYS
# 作用：definition drafts 保留天数（超过后可自动清理）。
# 示例：30
# 含义：只清理 draft，不影响已发布 releases。
DRAFT_TTL_DAYS=30

# ----------------------
# Retention cleaner（需 WORKER_ROLES 包含 maintenance）
# ----------------------

# RETENTION_CLEANER_ENABLED
# 作用：是否启用 retention cleaner 定时任务。
# 示例：true
# 含义：仅当 WORKER_ROLES 含 maintenance 时才生效。
RETENTION_CLEANER_ENABLED=true

# RETENTION_CLEANER_CRON
# 作用：retention cleaner 的 cron 表达式（包含“秒”字段）。
# 示例：0 */10 * * * *（每 10 分钟）
# 含义：用 cron 包解析；生产建议错峰运行以减少 DB 抖动。
RETENTION_CLEANER_CRON=0 */10 * * * *

# RETENTION_BATCH_SIZE
# 作用：retention 每批处理条数（避免长事务）。
# 示例：500
# 含义：过大可能导致锁持有时间过长；过小则清理速度慢。
RETENTION_BATCH_SIZE=500

