{
  "name": "compute-engine-backend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint .",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/adapters/outbound/db/typeorm/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/adapters/outbound/db/typeorm/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/adapters/outbound/db/typeorm/data-source.ts",
    "migration:show:prod": "typeorm migration:show -d dist/adapters/outbound/db/typeorm/data-source.js",
    "migration:run:prod": "typeorm migration:run -d dist/adapters/outbound/db/typeorm/data-source.js",
    "migration:revert:prod": "typeorm migration:revert -d dist/adapters/outbound/db/typeorm/data-source.js",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "start:worker": "ts-node -r tsconfig-paths/register src/worker.ts",
    "start:worker:prod": "node dist/worker.js",
    "test:hashing": "ts-node -r tsconfig-paths/register src/application/hashing/golden-cases.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "amqplib": "^0.10.9",
    "canonicalize": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.0",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
