# Provider Simulator 示例服务（env 示例）
#
# 目标：
# - 提供全局 facts 管理 + 业务输入模拟
# - 发布 compute.job.requested.v1 到 MQ
# - 订阅 compute.job.succeeded/failed.v1 并保存结果（用于仪表盘演示）

# HTTP_PORT
# 含义：本服务 HTTP 端口
HTTP_PORT=4020

# RABBITMQ_URL
# 含义：RabbitMQ 连接串（必须）
# 示例：amqp://guest:guest@localhost:5672
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# MQ_COMMANDS_EXCHANGE
# 含义：Compute Engine Commands exchange（投递 job.requested）
MQ_COMMANDS_EXCHANGE=compute.commands

# MQ_EVENTS_EXCHANGE
# 含义：Compute Engine Events exchange（订阅 job.succeeded/failed）
MQ_EVENTS_EXCHANGE=compute.events

# MQ_JOB_REQUESTED_ROUTING_KEY
# 含义：投递 routing key
MQ_JOB_REQUESTED_ROUTING_KEY=compute.job.requested.v1

# MQ_RESULTS_QUEUE
# 含义：本服务用于订阅结果事件的队列名（会自动创建并 bind）
MQ_RESULTS_QUEUE=provider.simulator.results.v1

# STORAGE_PATH
# 含义：本服务本地持久化文件（JSON）
STORAGE_PATH=./data/provider-simulator.json

