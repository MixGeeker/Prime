{
  "globals": [],
  "entrypoints": [
    {
      "key": "main",
      "params": [
        { "name": "basePrice", "valueType": "Decimal", "required": true, "description": "基础价格" },
        { "name": "taxRate", "valueType": "Ratio", "required": true, "description": "税率(0..1)" },
        { "name": "discountRate", "valueType": "Ratio", "required": true, "description": "折扣(0..1)" }
      ],
      "to": { "nodeId": "n_start", "port": "in" }
    }
  ],
  "locals": [],
  "nodes": [
    { "id": "n_start", "nodeType": "flow.noop" },
    { "id": "n_return", "nodeType": "flow.return" },

    { "id": "n_base", "nodeType": "inputs.params.decimal", "params": { "name": "basePrice" } },
    { "id": "n_taxRate", "nodeType": "inputs.params.ratio", "params": { "name": "taxRate" } },
    { "id": "n_discountRate", "nodeType": "inputs.params.ratio", "params": { "name": "discountRate" } },

    { "id": "n_tax", "nodeType": "math.mul" },
    { "id": "n_priceWithTax", "nodeType": "math.add" },

    { "id": "n_one", "nodeType": "core.const.decimal", "params": { "value": "1" } },
    { "id": "n_discountFactor", "nodeType": "math.sub" },

    { "id": "n_final", "nodeType": "math.mul" }
  ],
  "edges": [
    { "from": { "nodeId": "n_base", "port": "value" }, "to": { "nodeId": "n_tax", "port": "a" } },
    { "from": { "nodeId": "n_taxRate", "port": "value" }, "to": { "nodeId": "n_tax", "port": "b" } },

    { "from": { "nodeId": "n_base", "port": "value" }, "to": { "nodeId": "n_priceWithTax", "port": "a" } },
    { "from": { "nodeId": "n_tax", "port": "value" }, "to": { "nodeId": "n_priceWithTax", "port": "b" } },

    { "from": { "nodeId": "n_one", "port": "value" }, "to": { "nodeId": "n_discountFactor", "port": "a" } },
    { "from": { "nodeId": "n_discountRate", "port": "value" }, "to": { "nodeId": "n_discountFactor", "port": "b" } },

    { "from": { "nodeId": "n_priceWithTax", "port": "value" }, "to": { "nodeId": "n_final", "port": "a" } },
    { "from": { "nodeId": "n_discountFactor", "port": "value" }, "to": { "nodeId": "n_final", "port": "b" } }
  ],
  "execEdges": [
    { "from": { "nodeId": "n_start", "port": "out" }, "to": { "nodeId": "n_return", "port": "in" } }
  ],
  "outputs": [
    {
      "key": "finalPrice",
      "valueType": "Decimal",
      "from": { "nodeId": "n_final", "port": "value" },
      "rounding": { "scale": 2, "mode": "HALF_UP" }
    }
  ],
  "metadata": {
    "ui": {
      "nodes": {
        "n_start": { "x": 0, "y": 0 },
        "n_return": { "x": 920, "y": 0 },

        "n_base": { "x": -260, "y": -180 },
        "n_taxRate": { "x": -260, "y": -70 },
        "n_discountRate": { "x": -260, "y": 40 },

        "n_tax": { "x": 80, "y": -140 },
        "n_priceWithTax": { "x": 360, "y": -140 },

        "n_one": { "x": 80, "y": 20 },
        "n_discountFactor": { "x": 360, "y": 20 },

        "n_final": { "x": 650, "y": -60 }
      }
    }
  }
}

