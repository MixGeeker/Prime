# 前端运行时配置（示例）
#
# 说明：
# - Vite 仅会把以 `VITE_` 开头的变量注入到前端代码（import.meta.env）
# - 生产部署建议通过 Nginx/Ingress 注入（或 build-time 注入）

# VITE_BACKEND_BASE_URL
# 含义：Compute Engine Backend 的 HTTP 地址（Admin API + Catalog + Health）
# 示例：本地后端默认端口是 4010
VITE_BACKEND_BASE_URL=http://localhost:4010

# VITE_PROVIDER_SIMULATOR_BASE_URL
# 含义：Provider Simulator 示例服务地址（用于端到端演示：模拟 inputs + 投递 MQ + 订阅结果）
# 示例：本地示例服务默认端口建议 4020
VITE_PROVIDER_SIMULATOR_BASE_URL=http://localhost:4020

# VITE_ADMIN_TOKEN（可选）
# 含义：危险运维端点（例如 DLQ replay）所需的 Bearer token（仅用于本地 demo）
# 说明：UI 中也可以手动填写并保存到浏览器 localStorage
VITE_ADMIN_TOKEN=

